{
  "crons": [
    {
      "path": "/api/cron/stale-matters",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/email-verification",
      "schedule": "0 7 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://vercel.live blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://vercel.live; connect-src 'self' https://vercel.live https://*.vercel.live wss://*.vercel.live;"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "https://humri.org"
        }
      ]
    }
  ]
}
